---
export const prerender = false;

import { getRedisClient } from '../../lib/redis';

const SHARE_ID = Astro.params.id ?? '';
const IS_VALID_SHARE_ID = /^[a-z0-9]{4,10}$/.test(SHARE_ID);

const FALLBACK_AMOUNT = '150...';
const APP_EMOJI_POOL = ['💸', '🍻', '🧉', '🎉', '😎', '🍕', '🚕', '🏝️'];

const parseMoneyValue = (value: unknown): number => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value !== 'string') return NaN;

  const raw = value.trim();
  if (!raw) return NaN;

  const clean = raw.replace(/[^\d,.-]/g, '');
  if (!clean) return NaN;

  const lastComma = clean.lastIndexOf(',');
  const lastDot = clean.lastIndexOf('.');

  let normalized = clean;
  if (lastComma > -1 && lastDot > -1) {
    const decimalSep = lastComma > lastDot ? ',' : '.';
    const groupSep = decimalSep === ',' ? '.' : ',';
    normalized = clean
      .replace(new RegExp(`\\${groupSep}`, 'g'), '')
      .replace(decimalSep, '.');
  } else if (lastComma > -1) {
    normalized = clean.replace(/\./g, '').replace(',', '.');
  } else {
    normalized = clean.replace(/,/g, '');
  }

  const parsed = Number(normalized);
  return Number.isFinite(parsed) ? parsed : NaN;
};

const sumExpensesBase = (expenses: unknown): number => {
  if (!Array.isArray(expenses)) return 0;

  return expenses.reduce((acc, expense) => {
    const row = expense as Record<string, unknown>;
    const base = parseMoneyValue(row.amountInBase);
    const amount = parseMoneyValue(row.amount);

    if (Number.isFinite(base)) return acc + base;
    if (Number.isFinite(amount)) return acc + amount;
    return acc;
  }, 0);
};

const getTensionAmount = (value: number): string => {
  const rawDigits = Math.abs(Math.round(value)).toString().replace(/\D/g, '');
  const head = (rawDigits || '0').slice(0, 3).padEnd(3, '0');
  return `${head}...`;
};

const getEmojiTrio = (seedText: string): string => {
  const hash = seedText
    .split('')
    .reduce((acc, ch) => acc + ch.charCodeAt(0), 0);
  const start = hash % APP_EMOJI_POOL.length;
  const trio = [0, 1, 2].map(
    offset => APP_EMOJI_POOL[(start + offset) % APP_EMOJI_POOL.length],
  );
  return trio.join(' ');
};

let totalInBase = 0;
let emojiTrio = '💸 🍻 🧉';
let shouldRedirect = false;

if (IS_VALID_SHARE_ID) {
  emojiTrio = getEmojiTrio(SHARE_ID);
  try {
    const redis = await getRedisClient();
    const raw = await redis.get<string>(`s:${SHARE_ID}`);

    if (raw) {
      const parsed = JSON.parse(raw) as Record<string, unknown>;
      const expenses = Array.isArray(parsed.expenses) ? parsed.expenses : [];
      totalInBase = sumExpensesBase(expenses);
      shouldRedirect = true;
    }
  } catch (error) {
    console.error('[GET /s/:id]', error);
  }
}

const TOTAL_INT = Math.round(totalInBase);
const TENSION_AMOUNT = getTensionAmount(TOTAL_INT);
const SHARE_AMOUNT = shouldRedirect ? TENSION_AMOUNT : FALLBACK_AMOUNT;
const TITLE = `La Jodita | ${SHARE_AMOUNT} :$`;
const OG_DESCRIPTION = shouldRedirect
  ? 'Divide gastos y saldá cuentas entre amigos en segundos.'
  : 'Divide gastos y saldá cuentas entre amigos en segundos.';
const OG_IMAGE =
  IS_VALID_SHARE_ID && SHARE_ID
    ? `${Astro.url.origin}/api/og/${SHARE_ID}.png`
    : `${Astro.url.origin}/api/og/default.png`;
const DESTINATION = `/?s=${encodeURIComponent(SHARE_ID)}`;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Charset & Viewport -->
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />

    <!-- SEO Básico -->
    <title>{TITLE}</title>
    <meta
      name="description"
      content={OG_DESCRIPTION}
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large"
    />
    <meta
      name="language"
      content="es"
    />

    <!-- Open Graph (Facebook, LinkedIn, etc) -->
    <meta
      property="og:type"
      content="website"
    />
    <meta
      property="og:site_name"
      content="La Jodita"
    />
    <meta
      property="og:title"
      content={TITLE}
    />
    <meta
      property="og:description"
      content={OG_DESCRIPTION}
    />
    <meta
      property="og:url"
      content={Astro.url.href}
    />
    <meta
      property="og:image"
      content={OG_IMAGE}
    />
    <meta
      property="og:image:width"
      content="1200"
    />
    <meta
      property="og:image:height"
      content="630"
    />
    <meta
      property="og:locale"
      content="es_AR"
    />

    <!-- Twitter Card -->
    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta
      name="twitter:title"
      content={TITLE}
    />
    <meta
      name="twitter:description"
      content={OG_DESCRIPTION}
    />
    <meta
      name="twitter:image"
      content={OG_IMAGE}
    />

    <!-- Favicon & Icons -->
    <link
      rel="icon"
      href="/icon/la-jodita.svg"
      type="image/svg+xml"
    />
    <link
      rel="apple-touch-icon"
      href="/icon/la-jodita.svg"
    />

    <!-- Theme & Color -->
    <meta
      name="theme-color"
      content="#6c5ce7"
    />

    <!-- Canonical URL -->
    <link
      rel="canonical"
      href="https://la-jodita.vercel.app/"
    />

    <!-- Performance -->
    <link
      rel="preconnect"
      href="https://api.upstash.io"
    />
    <link
      rel="dns-prefetch"
      href="https://api.upstash.io"
    />

    {
      shouldRedirect && (
        <meta
          http-equiv="refresh"
          content={`0; url=${DESTINATION}`}
        />
      )
    }
  </head>
  <body></body>
</html>
